graph TD
    %% Styling
    classDef default fill:#111,stroke:#333,stroke-width:1px,color:#fff;
    classDef userbox fill:#1e1e2e,stroke:#7c3aed,stroke-width:2px,color:#fff;
    classDef local fill:#0f172a,stroke:#3b82f6,stroke-width:1px,color:#fff;
    classDef cloud fill:#2d1b69,stroke:#8b5cf6,stroke-width:1px,color:#fff;
    classDef green fill:#064e3b,stroke:#16a34a,stroke-width:2px,color:#fff;
    classDef yellow fill:#78350f,stroke:#d97706,stroke-width:2px,color:#fff;
    classDef red fill:#7f1d1d,stroke:#dc2626,stroke-width:2px,color:#fff;
    classDef gemini fill:#4c1d95,stroke:#7c3aed,stroke-width:2px,color:#fff;

    User["👤 USER"]:::userbox
    MacApp["💻 Mac App (PWA)"]:::local
    Helper["⚙️ Helper Server<br/>(localhost:8766 HTTP)"]:::local

    User -- "Voice / UI Interaction" --> MacApp
    MacApp -- "Start/Stop" --> Helper

    subgraph "Local Mac Agent (Runtime)"
        WsServer["📡 WebSocket Server<br/>(localhost:8765 WS)"]:::local
        Voice["🎙️ voice.py<br/>(Multimodal Hub)"]:::gemini
        Gemini{"✨ Gemini Live API"}:::gemini
        Classifier["🧠 classifier.py<br/>(Risk Tiers)"]:::local
        Gate["🛡️ gate.py<br/>(Security Gate)"]:::local
        
        State["🔄 State Machine<br/>(LISTENING -> THINKING -> EXECUTING)"]:::local

        TierG["🟢 GREEN (Silent)"]:::green
        TierY["🟡 YELLOW (Voice)"]:::yellow
        TierR["🔴 RED (Biometric)"]:::red
        
        Executor["⚡ screen_executor.py<br/>(Native Driver)"]:::local
        Tools[/"🖥️ OS Interaction<br/>pyautogui, mss, clipboard"/]:::local

        MacApp -. "State / Waveforms" .-> WsServer
        WsServer -.-> Voice
        Voice <--> Gemini
        Voice --> Classifier
        Classifier --> Gate
        Gate --> State
        State --> TierG
        State --> TierY
        State --> TierR
        TierG --> Executor
        TierY -- "Confirmed Verbally" --> Executor
        TierR -- "Approved via FaceID/TouchID" --> Executor
        Executor --> Tools
    end

    subgraph "GCP Backend (Cloud Run)"
        Backend["☁️ FastAPI Server"]:::cloud
        DB[("🗄️ Firestore<br/>Security State & Audit")]:::cloud
        
        Gate -- "Auth Handshake & Logging" --> Backend
        Backend --> DB
    end
    
    subgraph "Remote Monitoring & Auth"
        Dashboard["📊 Audit Dashboard"]:::userbox
        Mobile["📱 Mobile PWA"]:::userbox
        
        Backend -- "Real-time Stream (SSE)" --> Dashboard
        Backend <--> Mobile
    end

# Aegis Production Environment Configuration
# ------------------------------------------

# [API Keys]
# ALWAYS use Secret Manager for production keys (GOOGLE_API_KEY, FCM_KEY)
# These are kept here only as environment fallbacks if not using GSM.
GOOGLE_API_KEY=
FCM_KEY=

# [System Config]
PROJECT_ID=project-alpha-aegis
USER_ID=username
AEGIS_PIN=000000

# [URLs]
BACKEND_URL=https://apiaegis.projectalpha.in
DASHBOARD_URL=https://aegisdashboard.projectalpha.in

# [WebAuthn]
WEBAUTHN_RP_ID=aegismobile.projectalpha.in
WEBAUTHN_ORIGIN=https://aegismobile.projectalpha.in

# [CORS]
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://aegis.projectalpha.in,https://aegisdashboard.projectalpha.in,https://aegismac.projectalpha.in,https://aegismobile.projectalpha.in

# [Logging]
# Set to 'json' for structured logging in Cloud Run
LOG_FORMAT=json

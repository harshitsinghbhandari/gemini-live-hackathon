# Aegis Production Environment Configuration
# ------------------------------------------
# Copy this file to .env.production and fill in the values.
# NEVER commit .env.production to version control.
# For production deployments, prefer Google Secret Manager (GSM) for secrets.

# [API Keys]
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your-google-api-key-here
# Firebase Cloud Messaging key
FCM_KEY=your-fcm-key-here

# [System Config]
PROJECT_ID=your-project-id
USER_ID=your-username
AEGIS_PIN=000000

# [URLs]
BACKEND_URL=https://your-api-domain.example.com
DASHBOARD_URL=https://your-dashboard-domain.example.com

# [WebAuthn]
WEBAUTHN_RP_ID=your-app-domain.example.com
WEBAUTHN_ORIGIN=https://your-app-domain.example.com

# [CORS]
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-app-domain.example.com

# [Logging]
# Set to 'json' for structured logging in Cloud Run
LOG_FORMAT=json

{'function': {'name': 'GOOGLESHEETS_ADD_SHEET', 'description': "Adds a new sheet to a spreadsheet. Supports three sheet types: GRID, OBJECT, and DATA_SOURCE. SHEET TYPES: - GRID (default): Standard spreadsheet with rows/columns. Use properties to set dimensions, tab color, etc. - OBJECT: Sheet containing a chart. Requires objectSheetConfig with chartSpec (basicChart or pieChart). - DATA_SOURCE: Sheet connected to BigQuery. Requires dataSourceConfig with bigQuery spec and bigquery.readonly OAuth scope. OTHER NOTES: - Sheet names must be unique; use forceUnique=true to auto-append suffix (_2, _3) if name exists - For tab colors, use EITHER rgbColor OR themeColor, not both - Avoid 'index' when creating sheets in parallel (causes errors) - OBJECT sheets are created via addChart with position.newSheet=true - DATA_SOURCE sheets require bigquery.readonly OAuth scope Use cases: Add standard grid sheet, create chart on dedicated sheet, connect to BigQuery data source.", 'parameters': {'type': 'object', 'title': 'AddSheetRequest', 'required': ['spreadsheetId'], 'properties': {'title': {'type': 'string', 'title': 'Title', 'description': 'The name for the new sheet tab. Must be unique within the spreadsheet. Example: "Q3 Report", "Sales Data 2025". This is a convenience parameter - alternatively, you can set this via properties.title. Note: sheet_name is also accepted as an alias for title. Please provide a value of type string.', 'human_parameter_name': 'Sheet Name', 'human_parameter_description': 'The name for the new sheet tab. Must be unique within the spreadsheet.'}, 'properties': {'type': 'object', 'title': 'SheetProperties', 'properties': {'index': {'type': 'integer', 'title': 'Index', 'minimum': 0, 'description': "The zero-based index where the sheet should be inserted. Must be less than or equal to the current number of sheets. If not set, the sheet will be added at the end. Example: 0 for the first position. CONCURRENCY WARNING: Do not use 'index' when creating multiple sheets in parallel - this causes 'index is too high' errors. For parallel creation, omit this field and let sheets be added at the end.", 'human_parameter_name': 'Position Index', 'human_parameter_description': 'The position where the new sheet should appear (0 = first). Leave empty to add at the end.'}, 'title': {'type': 'string', 'title': 'Title', 'description': 'The name of the sheet. Must be unique within the spreadsheet. Example: "Q3 Report", "Sales Data 2025"', 'human_parameter_name': 'Sheet Name', 'human_parameter_description': 'The name for the new sheet tab. Must be unique within the spreadsheet.'}, 'hidden': {'type': 'boolean', 'title': 'Hidden', 'description': "True if the sheet is hidden in the UI, false if it's visible.", 'human_parameter_name': 'Hidden', 'human_parameter_description': 'Set to true to create a hidden sheet, or false/empty for a visible sheet.'}, 'sheetId': {'type': 'integer', 'title': 'Sheet Id', 'minimum': 0, 'description': 'The ID of the sheet. If not set, an ID will be randomly generated. Must be non-negative and unique within the spreadsheet. WARNING: Avoid setting this unless you need a specific ID.', 'human_parameter_name': 'Sheet ID', 'human_parameter_description': 'A specific numeric ID for the new sheet. Usually left empty to let Google auto-generate one.'}, 'sheetType': {'enum': ['GRID'], 'type': 'string', 'title': 'RequestSheetType', 'default': 'GRID', 'description': "Sheet type enum for AddSheetRequest.\n\nIMPORTANT: AddSheetRequest only supports creating GRID sheets.\n- For OBJECT sheets: Use 'Create Chart' action with position.newSheet=true\n- For DATA_SOURCE sheets: Use AddDataSourceRequest (requires extra scopes/permissions)", 'human_parameter_name': 'Sheet Type', 'human_parameter_description': 'The type of sheet. Only GRID (standard spreadsheet) is supported.'}, 'rightToLeft': {'type': 'boolean', 'title': 'Right To Left', 'description': "True if the sheet is an RTL sheet, false if it's LTR.", 'human_parameter_name': 'Right to Left', 'human_parameter_description': 'Set to true for right-to-left language sheets (e.g., Arabic, Hebrew).'}, 'tabColorStyle': {'type': 'object', 'title': 'ColorStyle', 'properties': {'rgbColor': {'type': 'object', 'title': 'Color', 'properties': {'red': {'type': 'number', 'title': 'Red', 'maximum': 1, 'minimum': 0, 'description': 'The amount of red in the color as a value in the interval [0, 1].', 'human_parameter_name': 'Red', 'human_parameter_description': 'The amount of red in the color as a value in the interval [0, 1].'}, 'blue': {'type': 'number', 'title': 'Blue', 'maximum': 1, 'minimum': 0, 'description': 'The amount of blue in the color as a value in the interval [0, 1].', 'human_parameter_name': 'Blue', 'human_parameter_description': 'The amount of blue in the color (0.0-1.0).'}, 'alpha': {'type': 'number', 'title': 'Alpha', 'maximum': 1, 'minimum': 0, 'description': 'The fraction of this color that should be applied to the pixel. E.g. 0.5 for 50% transparent.', 'human_parameter_name': 'Alpha', 'human_parameter_description': 'The transparency of the color (0.0-1.0).'}, 'green': {'type': 'number', 'title': 'Green', 'maximum': 1, 'minimum': 0, 'description': 'The amount of green in the color as a value in the interval [0, 1].', 'human_parameter_name': 'Green', 'human_parameter_description': 'The amount of green in the color (0.0-1.0).'}}, 'description': 'RGB color. Specify EITHER rgbColor OR themeColor, but not both. If using rgbColor, provide values for red, green, blue (0.0-1.0).', 'additionalProperties': False, 'human_parameter_name': 'Rgb Color', 'human_parameter_description': 'RGB color. Specify EITHER rgbColor OR themeColor, but not both. If using rgbColor, provide values fo'}, 'themeColor': {'enum': ['THEME_COLOR_TYPE_UNSPECIFIED', 'TEXT', 'BACKGROUND', 'ACCENT1', 'ACCENT2', 'ACCENT3', 'ACCENT4', 'ACCENT5', 'ACCENT6', 'LINK'], 'type': 'string', 'title': 'ThemeColorType', 'description': 'Theme color. Specify EITHER themeColor OR rgbColor, b
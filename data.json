arameter_name': 'Include Spreadsheet In Response', 'human_parameter_description': 'Determines if the update response should include the spreadsheet resource.'}}}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_DELETE_SHEET', 'description': 'Tool to delete a sheet (worksheet) from a spreadsheet. Use when you need to remove a specific sheet from a Google Sheet document.', 'parameters': {'type': 'object', 'title': 'DeleteSheetRequest', 'required': ['spreadsheetId', 'sheetId'], 'properties': {'sheetId': {'type': 'integer', 'title': 'Sheet Id', 'examples': [123456789], 'description': 'The ID of the sheet to delete. Note: A spreadsheet must contain at least one sheet, so you cannot delete the last remaining sheet. If the sheet is of DATA_SOURCE type, the associated DataSource is also deleted. Please provide a value of type integer. This parameter is required.', 'human_parameter_name': 'Sheet ID', 'human_parameter_description': 'Enter the ID of the specific sheet you wish to remove from the spreadsheet.'}, 'spreadsheetId': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['abc123xyz789'], 'description': 'The ID of the spreadsheet from which to delete the sheet. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet ID', 'human_parameter_description': 'Provide the unique identifier of the spreadsheet that contains the sheet you want to delete.'}, 'responseRanges': {'type': 'array', 'items': {'type': 'string', 'properties': {}}, 'title': 'Response Ranges', 'examples': [['Sheet1!A1:B10', 'Sheet2!C1:D20']], 'description': "Limits which ranges are returned when includeSpreadsheetInResponse is true. Only meaningful if includeSpreadsheetInResponse is set to true. Ranges should be in A1 notation (e.g., 'Sheet1!A1:B10').", 'human_parameter_name': 'Response Ranges', 'human_parameter_description': 'Specify which ranges to include in the response spreadsheet (requires includeSpreadsheetInResponse=true).'}, 'responseIncludeGridData': {'type': 'boolean', 'title': 'Response Include Grid Data', 'description': 'True if grid data should be returned in the response spreadsheet. Only meaningful when includeSpreadsheetInResponse is true and no field mask is set on the request. Please provide a value of type boolean.', 'human_parameter_name': 'Response Include Grid Data', 'human_parameter_description': 'Set to true to include cell data in the response (requires includeSpreadsheetInResponse=true).'}, 'includeSpreadsheetInResponse': {'type': 'boolean', 'title': 'Include Spreadsheet In Response', 'description': 'Determines if the spreadsheet resource should be returned in the response. If true, the response includes the updated spreadsheet resource with all its sheets, properties, and metadata. Please provide a value of type boolean.', 'human_parameter_name': 'Include Spreadsheet In Response', 'human_parameter_description': 'Set to true to receive the complete updated spreadsheet in the response.'}}}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_EXECUTE_SQL', 'description': 'DEPRECATED: Use direct Google Sheets actions instead: - GOOGLESHEETS_VALUES_GET / GOOGLESHEETS_BATCH_GET for reads - GOOGLESHEETS_VALUES_UPDATE / GOOGLESHEETS_UPDATE_VALUES_BATCH / GOOGLESHEETS_SPREADSHEETS_VALUES_APPEND for writes Execute SQL queries against Google Sheets tables. Supports SELECT, INSERT, UPDATE, DELETE operations and WITH clauses (CTEs) with familiar SQL syntax. Tables are automatically detected and mapped from the spreadsheet structure.', 'parameters': {'type': 'object', 'title': 'ExecuteSqlRequest', 'required': ['spreadsheet_id', 'sql'], 'properties': {'sql': {'type': 'string', 'title': 'Sql', 'examples': ['SELECT * FROM "Sales_Data" LIMIT 10', 'WITH ActiveUsers AS (SELECT * FROM "Users" WHERE status = \'active\') SELECT name, email FROM ActiveUsers', 'INSERT INTO "Customers" (name, email) VALUES (\'John Doe\', \'john@example.com\')', 'UPDATE "Inventory" SET quantity = quantity - 10 WHERE sku = \'ABC123\'', 'DELETE FROM "Old_Data" WHERE date < \'2023-01-01\''], 'description': 'Complete SQL query to execute. Must begin with SELECT, INSERT, UPDATE, DELETE, or WITH. Supports Common Table Expressions (CTEs) using WITH clause for complex queries. Note: WITH clauses require the sqlglot library for full support; simple SELECT/INSERT/UPDATE/DELETE operations work without it. Use table names (sheet names) in FROM/INTO clauses, not A1 range notation. The query must include proper SQL clauses (e.g., SELECT columns FROM table, not just a column name or condition). Example: SELECT * FROM "Sheet1" WHERE A = \'value\' (correct) instead of just A = \'value\' (incorrect). Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'SQL query', 'human_parameter_description': 'Enter the SQL command you wish to execute on the spreadsheet. This allows you to manipulate data directly using familiar SQL syntax.'}, 'dry_run': {'type': 'boolean', 'title': 'Dry Run', 'default': False, 'description': 'Preview changes without applying them (for write operations). Please provide a value of type boolean.', 'human_parameter_name': 'Preview changes?', 'human_parameter_description': "Select this option if you want to see what changes would be made without actually applying them. It's a safe way to check before executing."}, 'delete_method': {'enum': ['clear', 'remove_rows'], 'type': 'string', 'title': 'Delete Method', 'default': 'clear', 'description': "For DELETE operations: 'clear' preserves row structure, 'remove_rows' shifts data up. Please provide a value of type string.", 'human_parameter_name': 'Delete method', 'human_parameter_description': "Choose how you want to delete data. 'Clear' removes the content but keeps the structure, while 'remove_rows' deletes rows and shifts the remaining data up."}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'], 'description': "The unique alphanumeric ID of the Google Spreadsheet extracted from the URL. Format: A long string of letters, numbers, hyphens, and underscores (typically 44 characters). Find it in the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit. Must be a valid ID - values like 'auto' are NOT valid and will fail. Please provide a value of type string. This parameter is required.", 'human_parameter_name': 'Google Sheets ID', 'human_parameter_description': "Provide the unique ID of the Google Spreadsheet you want to work with. This is NOT 'auto' or any placeholder - it must be the actual ID from the spreadsheet URL. Example URL: https://docs.google.com/spreadsheets/d/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms/edit - the ID is '1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'."}}}, 'strict': None}, 'type': 'function'}

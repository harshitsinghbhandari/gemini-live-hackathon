{'function': {'name': 'GOOGLESHEETS_AGGREGATE_COLUMN_DATA', 'description': 'Searches for rows where a specific column matches a value and performs mathematical operations on data from another column.', 'parameters': {'type': 'object', 'title': 'AggregateColumnDataRequest', 'required': ['spreadsheet_id', 'sheet_name', 'target_column', 'operation'], 'properties': {'operation': {'enum': ['sum', 'average', 'count', 'min', 'max', 'percentage'], 'type': 'string', 'title': 'Operation', 'examples': ['sum', 'average', 'count', 'min', 'max', 'percentage'], 'description': 'The mathematical operation to perform on the target column values. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Operation', 'human_parameter_description': 'Select the type of calculation you want to perform on the values from the target column.'}, 'sheet_name': {'type': 'string', 'title': 'Sheet Name', 'examples': ['Sheet1', 'Sales Data'], 'description': "The name of the specific sheet within the spreadsheet. Matching is case-insensitive. If no exact match is found, partial matches will be attempted (e.g., 'overview' will match 'Overview 2025'). Please provide a value of type string. This parameter is required.", 'human_parameter_name': 'Sheet Name', 'human_parameter_description': 'Specify which sheet in the spreadsheet you want to use for your data aggregation. Matching is case-insensitive and supports partial matches.'}, 'search_value': {'type': 'string', 'title': 'Search Value', 'examples': ['HSR', 'Sales', 'North Region'], 'description': 'The exact value to search for in the search column. Case-sensitive by default. If not provided (or if search_column is not provided), all rows in the target column will be aggregated without filtering. Please provide a value of type string.', 'human_parameter_name': 'Search Value', 'human_parameter_description': 'Provide the specific value you want to find in the selected search column. Leave empty to aggregate all rows.'}, 'search_column': {'type': 'string', 'title': 'Search Column', 'examples': ['A', 'Region', 'Department'], 'description': "The column to search in for filtering rows. Can be a letter (e.g., 'A', 'B') or column name from header row (e.g., 'Region', 'Department'). If not provided, all rows in the target column will be aggregated without filtering. Please provide a value of type string.", 'human_parameter_name': 'Search Column', 'human_parameter_description': 'Indicate the column you want to look through to find matching values. Leave empty to aggregate all rows.'}, 'target_column': {'type': 'string', 'title': 'Target Column', 'examples': ['D', 'Sales', 'Revenue'], 'description': "The column to aggregate data from. Can be a letter (e.g., 'C', 'D') or column name from header row (e.g., 'Sales', 'Revenue'). Please provide a value of type string. This parameter is required.", 'human_parameter_name': 'Target Column', 'human_parameter_description': 'This is the column from which you want to gather and perform calculations on data.'}, 'case_sensitive': {'type': 'boolean', 'title': 'Case Sensitive', 'default': True, 'examples': [True, False], 'description': 'Whether the search should be case-sensitive. Please provide a value of type boolean.', 'human_parameter_name': 'Case Sensitive', 'human_parameter_description': 'Decide if the search should match upper and lower case letters exactly.'}, 'has_header_row': {'type': 'boolean', 'title': 'Has Header Row', 'default': True, 'examples': [True, False], 'description': 'Whether the first row contains column headers. If True, column names can be used for search_column and target_column. Please provide a value of type boolean.', 'human_parameter_name': 'Has Header Row', 'human_parameter_description': 'Indicate if your data has column names in the first row, which helps in identifying columns by name.'}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'], 'description': 'The unique identifier of the Google Sheets spreadsheet. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet Id', 'human_parameter_description': 'The unique ID for locating the specific spreadsheet you want to work with.'}, 'percentage_total': {'type': 'number', 'title': 'Percentage Total', 'examples': [10000, 50000.5], 'description': 'For percentage operation, the total value to calculate percentage against. If not provided, uses sum of all values in target column. Please provide a value of type number.', 'human_parameter_name': 'Percentage Total', 'human_parameter_description': "If you're calculating a percentage, this is the total value to compare against. If you leave this blank, it will use the total of the target column."}}, 'description': 'Request to search for rows matching a column value and aggregate data from another column.'}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_APPEND_DIMENSION', 'description': 'Tool to append new rows or columns to a sheet, increasing its size. Use when you need to add empty rows or columns to an existing sheet.', 'parameters': {'type': 'object', 'title': 'AppendDimensionRequest', 'required': ['spreadsheet_id', 'sheet_id', 'dimension', 'length'], 'properties': {'length': {'type': 'integer', 'title': 'Length', 'examples': [10], 'description': 'The number of rows or columns to append. Please provide a value of type integer. This parameter is required.', 'human_parameter_name': 'Length', 'human_parameter_description': 'Specify how many new rows or columns you want to add to the sheet.'}, 'sheet_id': {'type': 'integer', 'title': 'Sheet Id', 'examples': [0], 'description': "The numeric ID of the sheet (not the sheet name). This is a non-negative integer found in the sheet's URL as the 'gid' parameter (e.g., gid=0) or in the sheet properties. The first sheet in a spreadsheet typically has sheet_id=0. Please provide a value of type integer. This parameter is required.", 'human_parameter_name': 'Sheet ID', 'human_parameter_description': "Provide the numeric sheet ID (not the sheet name). Find it in the URL 'gid' parameter or use GOOGLESHEETS_GET_SHEET_NAMES to retrieve sheet IDs. The first sheet typically has ID 0."}, 'dimension': {'enum': ['ROWS', 'COLUMNS'], 'type': 'string', 'title': 'Dimension', 'examples': ['ROWS'], 'description': 'Specifies whether to append rows or columns. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Dimension Type', 'human_parameter_description': 'Indicate whether you want to append rows or columns to the sheet.'}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1q2w3e4r5t6y7u8i9o0p'], 'description': 'The ID of the spreadsheet. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet Id', 'human_parameter_description': 'The ID of the spreadsheet.'}, 'response_ranges': {'type': 'array', 'items': {'type': 'string', 'properties': {}}, 'title': 'Response Ranges', 'description': 'Limits the ranges of the spreadsheet to include in the response.', 'human_parameter_name': 'Response Ranges', 'human_parameter_description': 'Limit the response to only include data from specific ranges in the spreadsheet.'}, 'response_include_grid_data': {'type': 'boolean', 'title': 'Response Include Grid Data', 'description': 'True if grid data should be included in the response (if includeSpreadsheetInResponse is true). Please provide a value of type boolean.', 'human_parameter_name': 'Include Grid Data?', 'human_parameter_description': 'Set to true to include the actual cell data in the response when includeSpreadsheetInResponse is also true.'}, 'include_spreadsheet_in_response': {'type': 'boolean', 'title': 'Include Spreadsheet In Response', 'description': 'True if the updated spreadsheet should be included in the response. Please provide a value of type boolean.', 'human_parameter_name': 'Include Spreadsheet in Response?', 'human_parameter_description': 'Set to true if you want the full updated spreadsheet data returned in the response.'}}}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_BATCH_GET', 'description': 'Retrieves data from specified cell ranges in a Google Spreadsheet.', 'parameters': {'type': 'object', 'title': 'BatchGetRequest', 'required': ['spreadsheet_id'], 'properties': {'ranges': {'type': 'array', 'items': {'type': 'string', 'properties': {}}, 'title': 'Ranges', 'examples': ['Sheet1', 'Sheet1!A1:B2', 'Sheet1!A1:Z10000', 'Sheet1!1:2', "'My Sheet'!A1:Z500", 'A1:B2'], 'description': 'A list of cell ranges in A1 notation from which to retrieve data. If this list is omitted, empty, or contains only empty strings, all data from the first sheet of the spreadsheet will be fetched. Empty strings in the list are automatically filtered out. Supported formats: (1) Bare sheet name like \'Sheet1\' to get all data from that sheet, (2) Sheet with range like \'Sheet1!A1:B2\', (3) Just cell reference like \'A1:B2\' (uses first sheet). For sheet names with spaces or special characters, enclose in single quotes (e.g., "\'My Sheet\'" or "\'My Sheet\'!A1:B2"). IMPORTANT: For large sheets, always use bounded ranges with explicit row limits (e.g., \'Sheet1!A1:Z10000\' instead of \'Sheet1!A:Z\'). Unbounded column ranges like \'A:Z\' on sheets with >10,000 rows may cause timeouts or errors. If you need all data from a large sheet, fetch in chunks of 10,000 rows at a time.', 'human_parameter_name': 'Cell Ranges', 'human_parameter_description': 'Specify the ranges of cells you want to retrieve data from. You can list multiple ranges here. For large sheets, use bounded ranges with row limits to avoid timeouts.'}, 'majorDimension': {'enum': ['DIMENSION_UNSPECIFIED', 'ROWS', 'COLUMNS'], 'type': 'string', 'title': 'MajorDimension', 'description': 'The major dimension for organizing data in results. Please provide a value of type string.', 'human_parameter_name': 'Major Dimension', 'human_parameter_description': "Indicate whether you want your data organized by rows or columns. If you're not sure, it defaults to rows."}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'], 'maxLength': 200, 'description': 'The unique identifier of the Google Spreadsheet from which data will be retrieved. This is the ID found in the spreadsheet URL after /d/. You can provide either the spreadsheet ID directly or a full Google Sheets URL (the ID will be extracted automatically). Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet ID', 'human_parameter_description': 'Provide the ID of the Google Spreadsheet you want to access. You can find this in the URL of the spreadsheet.'}, 'valueRenderOption': {'enum': ['FORMATTED_VALUE', 'UNFORMATTED_VALUE', 'FORMULA'], 'type': 'string', 'title': 'Value Render Option', 'default': 'FORMATTED_VALUE', 'description': 'How values should be rendered in the output. FORMATTED_VALUE: Values are calculated and formatted (default). UNFORMATTED_VALUE: Values are calculated but not formatted. FORMULA: Values are not calculated; the formula is returned instead. Please provide a value of type string.', 'human_parameter_name': 'Value Render Option', 'human_parameter_description': 'Choose how you want the values to be displayed. You can get them formatted, unformatted, or as formulas.'}, 'dateTimeRenderOption': {'enum': ['SERIAL_NUMBER', 'FORMATTED_STRING'], 'type': 'string', 'title': 'Date Time Render Option', 'default': 'SERIAL_NUMBER', 'description': 'How dates and times should be rendered in the output. SERIAL_NUMBER: Dates are returned as serial numbers (default). FORMATTED_STRING: Dates returned as formatted strings. Please provide a value of type string.', 'human_parameter_name': 'Date Time Render Option', 'human_parameter_description': 'Select how you want dates and times to be represented in the output. You can choose between numbers or formatted strings.'}, 'empty_strings_filtered': {'type': 'boolean', 'title': 'Empty Strings Filtered', 'default': False, 'description': 'Please provide a value of type boolean.'}}}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_BATCH_UPDATE', 'description': 'Write values to ONE range in a Google Sheet, or append as new rows if no start cell is given. IMPORTANT - This tool does NOT accept the Google Sheets API\'s native batch format: - WRONG: {"data": [{"range": "...", "values": [[...]]}], ...} - CORRECT: {"sheet_name": "...", "values": [[...]], "first_cell_location": "...", ...} To update MULTIPLE ranges, make SEPARATE CALLS to this tool for each range. Features: - Auto-expands grid for large datasets (prevents range errors) - Set first_cell_location to write at a specific position (e.g., "A1", "B5") - Omit first_cell_location to append values as new rows at the end Requirements: Target sheet must exist and spreadsheet must contain at least one worksheet.', 'parameters': {'type': 'object', 'title': 'BatchUpdateRequest', 'required': ['spreadsheet_id', 'sheet_name', 'values'], 'properties': {'values': {'type': 'array', 'items': {'type': 'array', 'items': {'anyOf': [{'type': 'string'}, {'type': 'integer'}, {'type': 'number'}, {'type': 'boolean'}, {'type': 'null'}]}, 'properties': {}}, 'title': 'Values', 'examples': [[['Item', 'Cost', 'Stocked', 'Ship Date'], ['Wheel', 20.5, True, '2020-06-01'], ['Screw', 0.5, True, '2020-06-03'], ['Nut', 0.25, False, '2020-06-02']]], 'description': 'A 2D array of cell values where each inner array represents a row. Values can be strings, numbers, booleans, or None/null for empty cells. Ensure columns are properly aligned across rows. This parameter is required.', 'human_parameter_name': 'Values', 'human_parameter_description': 'Provide the actual data you want to enter into the sheet, organized in rows and columns.'}, 'sheet_name': {'type': 'string', 'title': 'Sheet Name', 'examples': ['Sheet1', 'Sales Data', 'Budget'], 'description': "The name of the specific sheet (tab) within the spreadsheet to update (required, separate from cell reference). Case-insensitive matching is supported (e.g., 'sheet1' will match 'Sheet1'). Note: Default sheet names are locale-dependent (e.g., 'Sheet1' in English, 'Foglio1' in Italian, 'Hoja 1' in Spanish, '시트1' in Korean, 'Feuille 1' in French). If you specify a common default name like 'Sheet1' and it doesn't exist, the action will automatically use the first sheet in the spreadsheet. Please provide a value of type string. This parameter is required.", 'human_parameter_name': 'Sheet Name', 'human_parameter_description': "Provide the name of the sheet you want to update. Case-insensitive matching is supported, so 'sheet1' will match 'Sheet1'."}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'], 'description': "The unique identifier of the Google Sheets spreadsheet to be updated. Must be an alphanumeric string (with hyphens and underscores allowed) typically 44 characters long. Can be found in the spreadsheet URL between '/d/' and '/edit'. Example: 'https://docs.google.com/spreadsheets/d/1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms/edit' has ID '1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'. Please provide a value of type string. This parameter is required.", 'human_parameter_name': 'Spreadsheet ID', 'human_parameter_description': 'The identifier for the Google Sheets document you want to modify. This can typically be found in the URL of the sheet.'}, 'valueInputOption': {'enum': ['RAW', 'USER_ENTERED'], 'type': 'string', 'title': 'Value Input Option', 'default': 'USER_ENTERED', 'examples': ['USER_ENTERED', 'RAW'], 'description': "How input data should be interpreted. 'USER_ENTERED': Values are parsed as if typed by a user (e.g., strings may become numbers/dates, formulas are calculated). 'RAW': Values are stored exactly as provided without parsing (e.g., '123' stays as string, '=SUM(A1:B1)' is not calculated). Please provide a value of type string.", 'human_parameter_name': 'Value Input Option', 'human_parameter_description': 'Specify how you would like the data to be treated when entered – either as user-typed values or as raw data.'}, 'first_cell_location': {'type': 'string', 'title': 'First Cell Location', 'examples': ['A1', 'D3', 'AA931'], 'description': "The starting cell for the update range, specified as a single cell in A1 notation WITHOUT sheet prefix (e.g., 'A1', 'B2', 'AA931'). The update will extend from this cell to the right and down based on the provided values. Sheet name must be provided separately in the 'sheet_name' field. If omitted or set to null, values are appended as new rows to the sheet. Note: Use only a single cell reference (e.g., 'AA931'), NOT a range (e.g., 'AA931:AF931') or sheet-prefixed notation (e.g., 'Sheet1!A1'). Please provide a value of type string.", 'human_parameter_name': 'First Cell Location', 'human_parameter_description': "Indicate where the update should start in the sheet. Use coordinates like 'A1' for the top-left cell."}, 'includeValuesInResponse': {'type': 'boolean', 'title': 'Include Values In Response', 'default': False, 'examples': [True, False], 'description': "If set to True, the response will include the updated values in the 'spreadsheet.responses[].updatedData' field. The updatedData object contains 'range' (A1 notation), 'majorDimension' (ROWS), and 'values' (2D array of the actual cell values after the update). Please provide a value of type boolean.", 'human_parameter_name': 'Include Values in Response?', 'human_parameter_description': "Choose whether you want to see the updated values in the response after the operation. When enabled, look for the data in the 'spreadsheet.responses[].updatedData.values' field."}}, 'description': 'Write values to ONE range in a Google Sheet, or append as new rows if no start cell is given.\n\nIMPORTANT: This tool does NOT accept the Google Sheets API\'s native batch format.\n- WRONG: {"data": [{"range": "Sheet1!A1", "values": [[...]]}], ...}  (Google API format)\n- CORRECT: {"sheet_name": "Sheet1", "values": [[...]], "first_cell_location": "A1", ...}\n\nTo update MULTIPLE ranges, make separate calls to this tool for each range.', 'additionalProperties': True}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_BATCH_UPDATE_VALUES_BY_DATA_FILTER', 'description': 'Tool to update values in ranges matching data filters. Use when you need to update specific data in a Google Sheet based on criteria rather than fixed cell ranges.', 'parameters': {'type': 'object', 'title': 'BatchUpdateValuesByDataFilterRequestModel', 'required': ['spreadsheetId', 'data', 'valueInputOption'], 'properties': {'data': {'type': 'array', 'items': {'type': 'object', 'title': 'DataFilterValueRange', 'required': ['dataFilter', 'values'], 'properties': {'values': {'type': 'array', 'items': {'type': 'array', 'items': {'anyOf': [{'type': 'string'}, {'type': 'integer'}, {'type': 'number'}, {'type': 'boolean'}]}, 'properties': {}}, 'title': 'Values', 'description': 'The data to be written. A two-dimensional array of values that will be written to the range. Values can be strings, numbers, or booleans. If the range is larger than the values array, the excess cells will not be changed. If the values array is larger than the range, the excess values will be ignored.', 'human_parameter_name': 'Values', 'human_parameter_description': 'The data to be written. A two-dimensional array of values that will be written to the range.'}, 'dataFilter': {'type': 'object', 'title': 'Data Filter', 'properties': {'a1Range': {'type': 'string', 'title': 'A1 Range', 'description': 'The A1 notation of the range to update.', 'human_parameter_name': 'A1 Range', 'human_parameter_description': 'The A1 notation of the range to update.'}, 'gridRange': {'type': 'object', 'title': 'GridRange', 'properties': {'sheetId': {'type': 'integer', 'title': 'Sheet Id', 'description': 'The sheet this range is on.', 'human_parameter_name': 'Sheet Id', 'human_parameter_description': 'The sheet this range is on.'}, 'endRowIndex': {'type': 'integer', 'title': 'End Row Index', 'description': 'The end row (exclusive) of the range, or not set if unbounded.', 'human_parameter_name': 'End Row Index', 'human_parameter_description': 'The end row (exclusive) of the range, or not set if unbounded.'}, 'startRowIndex': {'type': 'integer', 'title': 'Start Row Index', 'description': 'The start row (inclusive) of the range, or not set if unbounded.', 'human_parameter_name': 'Start Row Index', 'human_parameter_description': 'The start row (inclusive) of the range, or not set if unbounded.'}, 'endColumnIndex': {'type': 'integer', 'title': 'End Column Index', 'description': 'The end column (exclusive) of the range, or not set if unbounded.', 'human_parameter_name': 'End Column Index', 'human_parameter_description': 'The end column (exclusive) of the range, or not set if unbounded.'}, 'startColumnIndex': {'type': 'integer', 'title': 'Start Column Index', 'description': 'The start column (inclusive) of the range, or not set if unbounded.', 'human_parameter_name': 'Start Column Index', 'human_parameter_description': 'The start column (inclusive) of the range, or not set if unbounded.'}}, 'description': 'Selects data within the range described by a GridRange. This field is optional. If specified, the dataFilter selects data within the specified grid range.', 'additionalProperties': False, 'human_parameter_name': 'Grid Range', 'human_parameter_description': 'Selects data within the range described by a GridRange. This field is optional. If specified, the dataFilter selects data within the specified grid range.'}, 'developerMetadataLookup': {'type': 'object', 'title': 'DeveloperMetadataLookup', 'properties': {'metadataId': {'type': 'integer', 'title': 'Metadata Id', 'description': 'The ID of the developer metadata to match. This field is optional. If specified, the lookup matches only the developer metadata with the specified ID.', 'human_parameter_name': 'Metadata Id', 'human_parameter_description': 'The ID of the developer metadata to match.'}, 'visibility': {'type': 'string', 'title': 'Visibility', 'description': 'The visibility of the developer metadata to match. This field is optional. If specified, the lookup matches only the developer metadata with the specified visibility.', 'human_parameter_name': 'Visibility', 'human_parameter_description': 'The visibility of the developer metadata to match.'}, 'metadataKey': {'type': 'string', 'title': 'Metadata Key', 'description': 'The key of the developer metadata to match. This field is optional. If specified, the lookup matches only the developer metadata with the specified key.', 'human_parameter_name': 'Metadata Key', 'human_parameter_description': 'The key of the developer metadata to match.'}, 'locationType': {'enum': ['ROW', 'COLUMN', 'SHEET'], 'type': 'string', 'title': 'Location Type', 'description': 'The type of location this object is looking for. Valid values are ROW, COLUMN, and SHEET.', 'human_parameter_name': 'Location Type', 'human_parameter_description': 'The type of location this object is looking for.'}, 'metadataValue': {'type': 'string', 'title': 'Metadata Value', 'description': 'The value of the developer metadata to match. This field is optional. If specified, the lookup matches only the developer metadata with the specified value.', 'human_parameter_name': 'Metadata Value', 'human_parameter_description': 'The value of the developer metadata to match.'}, 'metadataLocation': {'type': 'object', 'title': 'DeveloperMetadataLocation', 'properties': {'sheetId': {'type': 'integer', 'title': 'Sheet Id', 'description': 'The ID of the sheet the location is on.', 'human_parameter_name': 'Sheet Id', 'human_parameter_description': 'The ID of the sheet the location is on.'}, 'spreadsheet': {'type': 'boolean', 'title': 'Spreadsheet', 'description': 'True if the metadata location is the spreadsheet itself.', 'human_parameter_name': 'Spreadsheet', 'human_parameter_description': 'True if the metadata location is the spreadsheet itself.'}, 'locationType': {'type': 'string', 'title': 'Location Type', 'description': 'The type of location this object represents. This field is read-only.', 'human_parameter_name': 'Location Type', 'human_parameter_description': 'The type of location this object represents.'}, 'dimensionRange': {'type': 'object', 'title': 'Dimension Range', 'description': 'A range along a single dimension on a sheet. All indexes are 0-based. Indexes are half open: the start index is inclusive and the end index is exclusive. Missing indexes indicate the range is unbounded on that side.', 'additionalProperties': True, 'human_parameter_name': 'Dimension Range', 'human_parameter_description': 'A range along a single dimension on a sheet.'}}, 'description': 'The location of the developer metadata to match. This field is optional. If specified, the lookup matches only the developer metadata in the specified location.', 'additionalProperties': False, 'human_parameter_name': 'Metadata Location', 'human_parameter_description': 'The location of the developer metadata to match.'}, 'locationMatchingStrategy': {'enum': ['EXACT', 'INTERSECTING'], 'type': 'string', 'title': 'Location Matching Strategy', 'description': 'Determines how this lookup matches the location. If this field is specified as EXACT, then the lookup requires an exact match of the specified locationType, metadataKey, and metadataValue. If this field is specified as INTERSECTING, then the lookup considers all metadata that intersects the specified locationType, and then filters that metadata by the specified key and value. If this field is unspecified, it is treated as EXACT.', 'human_parameter_name': 'Location Matching Strategy', 'human_parameter_description': 'Determines how this lookup matches the location.'}}, 'description': "Matches the data against the developer metadata that's associated with the dimensions. The developer metadata should be created with the location type set to either ROW or COLUMN and the visibility set to DOCUMENT.", 'additionalProperties': False, 'human_parameter_name': 'Developer Metadata Lookup', 'human_parameter_description': 'Matches the data against the developer metadata associated with the dimensions.'}}, 'description': 'The data filter describing the criteria to select cells for update.', 'additionalProperties': False, 'human_parameter_name': 'Data Filter', 'human_parameter_description': 'The data filter describing the criteria to select cells for update.'}, 'majorDimension': {'enum': ['ROWS', 'COLUMNS', 'DIMENSION_UNSPECIFIED'], 'type': 'string', 'title': 'Major Dimension', 'default': 'ROWS', 'description': 'The major dimension of the values. The default value is ROWS.', 'human_parameter_name': 'Major Dimension', 'human_parameter_description': 'The major dimension of the values. Use ROWS for row-wise data or COLUMNS for column-wise data.'}}}, 'title': 'Data', 'description': 'The new values to apply to the spreadsheet. If more than one range is matched by the specified DataFilter the specified values are applied to all of those ranges. Can be provided as a JSON string or as a list of DataFilterValueRange objects. This parameter is required.', 'human_parameter_name': 'Data', 'human_parameter_description': 'The new values to apply to the spreadsheet. If more than one range is matched by the specified DataFilter the specified values are applied to all of those ranges.'}, 'spreadsheetId': {'type': 'string', 'title': 'Spreadsheet Id', 'description': 'The ID of the spreadsheet to update. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet Id', 'human_parameter_description': 'The ID of the spreadsheet to update.'}, 'valueInputOption': {'enum': ['INPUT_VALUE_OPTION_UNSPECIFIED', 'RAW', 'USER_ENTERED'], 'type': 'string', 'title': 'Value Input Option', 'description': "How the input data should be interpreted. RAW: Values are stored exactly as entered, without parsing. USER_ENTERED: Values are parsed as if typed by a user (numbers stay numbers, strings prefixed with '=' become formulas, etc.). INPUT_VALUE_OPTION_UNSPECIFIED: Default input value option is not specified. Please provide a value of type string. This parameter is required.", 'human_parameter_name': 'Value Input Option', 'human_parameter_description': 'How the input data should be interpreted. Choose RAW for exact values, USER_ENTERED for automatic parsing, or INPUT_VALUE_OPTION_UNSPECIFIED for default behavior.'}, 'includeValuesInResponse': {'type': 'boolean', 'title': 'Include Values In Response', 'default': False, 'description': 'Determines if the update response should include the values of the cells that were updated. By default, responses do not include the updated values. Please provide a value of type boolean.', 'human_parameter_name': 'Include Values In Response', 'human_parameter_description': 'Determines if the update response should include the values of the cells that were updated. By default, responses do not include the updated values.'}, 'responseValueRenderOption': {'enum': ['FORMATTED_VALUE', 'UNFORMATTED_VALUE', 'FORMULA'], 'type': 'string', 'title': 'Response Value Render Option', 'default': 'FORMATTED_VALUE', 'description': 'Determines how values in the response should be rendered. The default render option is FORMATTED_VALUE. Please provide a value of type string.', 'human_parameter_name': 'Response Value Render Option', 'human_parameter_description': 'Determines how values in the response should be rendered.'}, 'responseDateTimeRenderOption': {'enum': ['SERIAL_NUMBER', 'FORMATTED_STRING'], 'type': 'string', 'title': 'Response Date Time Render Option', 'default': 'SERIAL_NUMBER', 'description': 'Determines how dates, times, and durations in the response should be rendered. This is ignored if responseValueRenderOption is FORMATTED_VALUE. The default dateTime render option is SERIAL_NUMBER. Please provide a value of type string.', 'human_parameter_name': 'Response Date Time Render Option', 'human_parameter_description': 'Determines how dates, times, and durations in the response should be rendered.'}}}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_CLEAR_BASIC_FILTER', 'description': 'Tool to clear the basic filter from a sheet. Use when you need to remove an existing basic filter from a specific sheet within a Google Spreadsheet.', 'parameters': {'type': 'object', 'title': 'ClearBasicFilterRequest', 'required': ['spreadsheet_id', 'sheet_id'], 'properties': {'sheet_id': {'type': 'integer', 'title': 'Sheet Id', 'examples': [0, 123456789], 'description': 'The ID of the sheet on which the basic filter should be cleared. Please provide a value of type integer. This parameter is required.', 'human_parameter_name': 'Sheet ID', 'human_parameter_description': 'Specify the ID of the sheet from which you want to remove the basic filter.'}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['abc123xyz789'], 'description': 'The ID of the spreadsheet. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet ID', 'human_parameter_description': 'Provide the unique identifier for the spreadsheet you want to modify.'}, 'response_ranges': {'type': 'array', 'items': {'type': 'string', 'properties': {}}, 'title': 'Response Ranges', 'description': 'Limits the ranges included in the response spreadsheet. Only applicable when include_spreadsheet_in_response is true.', 'human_parameter_name': 'Response Ranges', 'human_parameter_description': "List of A1 notation ranges to include in the response (e.g., ['Sheet1!A1:D5'])."}, 'response_include_grid_data': {'type': 'boolean', 'title': 'Response Include Grid Data', 'description': 'True if grid data should be returned in the response. Only applicable when include_spreadsheet_in_response is true. Please provide a value of type boolean.', 'human_parameter_name': 'Response Include Grid Data', 'human_parameter_description': 'Set to true to include the actual cell data in the response.'}, 'include_spreadsheet_in_response': {'type': 'boolean', 'title': 'Include Spreadsheet In Response'
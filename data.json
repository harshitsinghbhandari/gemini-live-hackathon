{'function': {'name': 'GOOGLEDOCS_COPY_DOCUMENT', 'description': "Tool to create a copy of an existing Google Document. Use this to duplicate a document, for example, when using an existing document as a template. The copied document will have a default title (e.g., 'Copy of [original title]') if no new title is provided, and will be placed in the user's root Google Drive folder.", 'parameters': {'type': 'object', 'title': 'CopyDocumentRequest', 'required': ['document_id'], 'properties': {'title': {'type': 'string', 'title': 'Title', 'examples': ['My New Document Title'], 'description': "The title for the new copied document. If not provided, the title will be 'Copy of [original document's title]'. Please provide a value of type string.", 'human_parameter_name': 'New Document Title', 'human_parameter_description': "The name you want to give to the new document copy. If you don't provide one, it will be automatically labeled as 'Copy of [original document's title]'."}, 'document_id': {'type': 'string', 'title': 'Document Id', 'examples': ['1a2b3c-example-document-id'], 'description': 'The ID of the Google Document to be copied. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Document ID', 'human_parameter_description': 'The unique identifier for the Google Document you wish to copy. This is essential for locating the document in your Google Drive.'}, 'include_shared_drives': {'type': 'boolean', 'title': 'Include Shared Drives', 'default': True, 'description': 'Whether to support copying documents from shared drives. Defaults to True. Please provide a value of type boolean.', 'human_parameter_name': 'Include shared drives', 'human_parameter_description': 'Enable copying documents from shared drives (team drives) you have access to.'}}}, 'strict': None}, 'type': 'function'}

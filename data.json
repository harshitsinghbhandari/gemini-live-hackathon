{'function': {'name': 'GOOGLETASKS_BATCH_EXECUTE', 'description': 'Executes multiple Google Tasks API operations in a single HTTP batch request and returns structured per-item results. Use this to reduce LLM tool invocations when performing bulk operations like updating many tasks, moving tasks, or deleting multiple items. Note: Each sub-request still counts toward API quota; batching primarily reduces HTTP overhead and tool call count.', 'parameters': {'type': 'object', 'title': 'BatchExecuteRequest', 'required': ['requests'], 'properties': {'requests': {'type': 'array', 'items': {'type': 'object', 'title': 'BatchSubRequest', 'required': ['id', 'method', 'path'], 'properties': {'id': {'type': 'string', 'title': 'Id', 'examples': ['task1', 'update_task_1', 'delete_list_3'], 'description': "Client-chosen unique identifier for this sub-request. Used to match responses to requests. Example: 'task1', 'delete_task_2'"}, 'path': {'type': 'string', 'title': 'Path', 'examples': ['/tasks/v1/lists/@default/tasks', '/tasks/v1/lists/list123/tasks/task456', '/tasks/v1/users/@me/lists'], 'description': "API endpoint path starting with '/tasks/v1/'. Do NOT include the host or base URL. Example: '/tasks/v1/lists/@default/tasks'"}, 'query': {'type': 'object', 'title': 'Query', 'description': "Query parameters for this sub-request as key-value pairs. Will be converted to querystring. Example: {'maxResults': 10, 'showCompleted': true}", 'additionalProperties': {'anyOf': [{'type': 'string'}, {'type': 'integer'}, {'type': 'boolean'}, {'type': 'number'}]}}, 'method': {'enum': ['GET', 'POST', 'PATCH', 'PUT', 'DELETE'], 'type': 'string', 'title': 'Method', 'examples': ['GET', 'POST', 'PATCH', 'DELETE'], 'description': 'HTTP method for this sub-request. Must be uppercase.'}, 'headers': {'type': 'object', 'title': 'Headers', 'description': 'Optional headers specific to this sub-request. Authorization is inherited from the batch request unless overridden here.', 'additionalProperties': {'type': 'string'}}, 'json_body': {'type': 'object', 'title': 'Json Body', 'description': "JSON body for POST/PATCH/PUT requests. Will be serialized as JSON. Example: {'title': 'New Task', 'status': 'needsAction'}", 'additionalProperties': {'anyOf': [{'type': 'string'}, {'type': 'integer'}, {'type': 'boolean'}, {'type': 'number'}, {'type': 'array', 'items': {}}, {'type': 'object', 'additionalProperties': True}, {'type': 'null'}]}}}, 'description': 'Represents a single HTTP request within a batch.'}, 'title': 'Requests', 'minItems': 1, 'description': 'Array of sub-requests to execute in this batch. Each sub-request is independent and will return its own result. This parameter is required.'}, 'max_requests': {'type': 'integer', 'title': 'Max Requests', 'default': 1000, 'maximum': 1000, 'minimum': 1, 'description': "Maximum number of sub-requests allowed in a single batch. Google's typical cap is 1000. Lower values can control response size. Please provide a value of type integer."}, 'validate_paths': {'type': 'boolean', 'title': 'Validate Paths', 'default': True, 'description': "When true (default), validates that all paths start with '/tasks/v1/' to prevent cross-API batch misuse. Set to false to disable validation. Please provide a value of type boolean."}}, 'description': 'Request model for batch execution of Google Tasks API calls.'}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLETASKS_BULK_INSERT_TASKS', 'description': 'Creates multiple tasks in a Google Tasks list in a single operation using HTTP batching. Use when you need to create many tasks efficiently (reducing round-trips compared to individual insert calls).', 'parameters': {'type': 'object', 'title': 'BulkInsertTasksRequest', 'required': ['tasklist_id', 'tasks'], 'properties': {'tasks': {'type': 'array', 'items': {'type': 'object', 'title': 'BulkTaskInput', 'required': ['title'], 'properties': {'due': {'type': 'string', 'title': 'Due', 'description': "Due date for the task in RFC3339 format (e.g., '2025-09-22T00:00:00Z'). Google Tasks only stores the date portion."}, 'notes': {'type': 'string', 'title': 'Notes', 'maxLength': 8192, 'description': 'Additional details or description for the task. Maximum 8192 characters.'}, 'title': {'type': 'string', 'title': 'Title', 'maxLength': 1024, 'minLength': 1, 'description': 'Title/name of the task (REQUIRED). Maximum 1024 characters.'}, 'parent': {'type': 'string', 'title': 'Parent', 'description': 'Identifier of parent task to create this as a subtask.'}, 'status': {'type': 'string', 'title': 'Status', 'default': 'needsAction', 'description': "Status of the task: 'needsAction' or 'completed'. Default: 'needsAction'"}, 'previous': {'type': 'string', 'title': 'Previous', 'description': 'Identifier of task after which this task should be placed.'}, 'completed': {'type': 'string', 'title': 'Completed', 'description': "Completion timestamp in RFC3339 format. Only applicable when status='completed'."}}, 'description': 'Defines input for a single task to be created in bulk.\nSubset of TaskInput without id/etag fields since these are new tasks.'}, 'title': 'Tasks', 'minItems': 1, 'description': 'Array of tasks to create. Each task requires at least a title. This parameter is required.'}, 'batch_size': {'type': 'integer', 'title': 'Batch Size', 'default': 50, 'maximum': 100, 'minimum': 1, 'description': 'Maximum number of tasks per batch request. Default: 50. Tasks exceeding this will be split into multiple batch calls. Please provide a value of type integer.'}, 'tasklist_id': {'type': 'string', 'title': 'Tasklist Id', 'examples': ['MDQ1NTEzMjc4OTM5MzM0NTY4NzE6MDow', 'N1FNZHM5Y0xYN3g5TzJBVQ'], 'description': "Identifier for the Google Task list where tasks will be created. Use actual task list IDs, not '@default'. Please provide a value of type string. This parameter is required."}}}, 'strict': None}, 'type': 'function'}

{'function': {'name': 'GOOGLESHEETS_FORMAT_CELL', 'description': 'Applies text and background cell formatting to a specified range in a Google Sheets worksheet.', 'parameters': {'type': 'object', 'title': 'FormatCellRequest', 'required': ['spreadsheet_id'], 'properties': {'red': {'type': 'number', 'title': 'Red', 'default': 0.9, 'examples': ['0.0', '0.5', '1.0'], 'description': 'Red component of the background color (0.0-1.0). Please provide a value of type number.', 'human_parameter_name': 'Red', 'human_parameter_description': 'Set the red color value for the background of the cells, ranging from 0 (no red) to 1 (full red).'}, 'blue': {'type': 'number', 'title': 'Blue', 'default': 0.9, 'examples': ['0.0', '0.5', '1.0'], 'description': 'Blue component of the background color (0.0-1.0). Please provide a value of type number.', 'human_parameter_name': 'Blue', 'human_parameter_description': 'Set the blue color value for the background of the cells, ranging from 0 (no blue) to 1 (full blue).'}, 'bold': {'type': 'boolean', 'title': 'Bold', 'default': False, 'examples': ['true', 'false'], 'description': 'Apply bold formatting. Please provide a value of type boolean.', 'human_parameter_name': 'Bold', 'human_parameter_description': 'Enable this to make the text in the selected cells bold.'}, 'green': {'type': 'number', 'title': 'Green', 'default': 0.9, 'examples': ['0.0', '0.5', '1.0'], 'description': 'Green component of the background color (0.0-1.0). Please provide a value of type number.', 'human_parameter_name': 'Green', 'human_parameter_description': 'Set the green color value for the background of the cells, ranging from 0 (no green) to 1 (full green).'}, 'range': {'type': 'string', 'title': 'Range', 'examples': ['A1', 'F9', 'B2:D4', 'C1:C10', 'A:C', 'I:J', '1:5'], 'description': "OPTION 1: Cell range in A1 notation (RECOMMENDED). Supports: single cells ('A1', 'F9'), cell ranges ('A1:B5'), entire columns ('A', 'I:J'), entire rows ('1', '1:5'). Provide EITHER this field OR all four index fields below, not both. Please provide a value of type string.", 'human_parameter_name': 'Range', 'human_parameter_description': 'The cell range you wish to format, specified in A1 notation. Choose this for ease of use.'}, 'italic': {'type': 'boolean', 'title': 'Italic', 'default': False, 'examples': ['true', 'false'], 'description': 'Apply italic formatting. Please provide a value of type boolean.', 'human_parameter_name': 'Italic', 'human_parameter_description': 'Enable this to style the text in the selected cells with italics.'}, 'fontSize': {'type': 'integer', 'title': 'Font Size', 'default': 10, 'examples': ['10', '12', '14'], 'description': 'Font size in points. Please provide a value of type integer.', 'human_parameter_name': 'Fontsize', 'human_parameter_description': 'Specify the size of the font in points for the text in the selected cells.'}, 'underline': {'type': 'boolean', 'title': 'Underline', 'default': False, 'examples': ['true', 'false'], 'description': 'Apply underline formatting. Please provide a value of type boolean.', 'human_parameter_name': 'Underline', 'human_parameter_description': 'Enable this to underline the text in the selected cells.'}, 'sheet_name': {'type': 'string', 'title': 'Sheet Name', 'examples': ['Sheet1', 'Q3 Report', 'Customer Data'], 'description': "The worksheet name/title (e.g., 'Sheet1', 'Q3 Report'). Provide either this field OR worksheet_id, not both. If both are provided, sheet_name takes precedence and will be resolved to worksheet_id. Please provide a value of type string.", 'human_parameter_name': 'Sheet Name', 'human_parameter_description': 'The name of the worksheet/tab you want to format. Use this for convenience instead of worksheet_id.'}, 'worksheet_id': {'type': 'integer', 'title': 'Worksheet Id', 'default': 0, 'examples': [0, 1534097477], 'description': 'The worksheet identifier. Accepts EITHER: (1) The sheetId from the Google Sheets API (a large number like 1534097477, obtainable via GOOGLESHEETS_GET_SPREADSHEET_INFO), OR (2) The 0-based positional index of the worksheet (0 for first sheet, 1 for second, etc.). The action will first try to match by sheetId, then fall back to matching by index. Defaults to 0 (first sheet). Provide either this field OR sheet_name, not both. Please provide a value of type integer.', 'human_parameter_name': 'Worksheet Id', 'human_parameter_description': 'The worksheet identifier - either the sheetId (large number from API) or 0-based index (0, 1, 2...). Defaults to the first sheet.'}, 'end_row_index': {'type': 'integer', 'title': 'End Row Index', 'examples': [1, 9], 'description': "OPTION 2: 0-based index of the row AFTER the last row (exclusive). Required if 'range' is not provided. Must provide ALL four index fields together. Please provide a value of type integer.", 'human_parameter_name': 'End Row Index', 'human_parameter_description': 'The row number right after the last row you want to format, counted from zero. This helps define the height of your range.'}, 'strikethrough': {'type': 'boolean', 'title': 'Strikethrough', 'default': False, 'examples': ['true', 'false'], 'description': 'Apply strikethrough formatting. Please provide a value of type boolean.', 'human_parameter_name': 'Strikethrough', 'human_parameter_description': 'Enable this to place a line through the text in the selected cells.'}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'], 'description': 'Identifier of the Google Sheets spreadsheet. Please provide a value of type string. This parameter is required.', 'human_parameter_name': 'Spreadsheet Id', 'human_parameter_description': 'The unique identifier for the Google Sheets document you want to modify.'}, 'start_row_index': {'type': 'integer', 'title': 'Start Row Index', 'examples': [0, 8], 'description': "OPTION 2: 0-based row index (row 1 = index 0, row 9 = index 8). Required if 'range' is not provided. Must provide ALL four index fields together. Please provide a value of type integer.", 'human_parameter_name': 'Start Row Index', 'human_parameter_description': 'The starting row number for the cell range, counted from zero. This is needed if you are using index values instead of A1 notation.'}, 'end_column_index': {'type': 'integer', 'title': 'End Column Index', 'examples': [1, 2, 6], 'description': "OPTION 2: 0-based index of the column AFTER the last column (exclusive). Required if 'range' is not provided. Must provide ALL four index fields together. Please provide a value of type integer.", 'human_parameter_name': 'End Column Index', 'human_parameter_description': 'The column number right after the last column you wish to format, counted from zero. This is necessary to finalize your range.'}, 'start_column_index': {'type': 'integer', 'title': 'Start Column Index', 'examples': [0, 1, 5], 'description': "OPTION 2: 0-based column index (A = 0, B = 1, F = 5). Required if 'range' is not provided. Must provide ALL four index fields together. Please provide a value of type integer.", 'human_parameter_name': 'Start Column Index', 'human_parameter_description': 'The starting column number for the cell range, counted from zero. Required when providing indices directly.'}}, 'description': 'Parameters for applying formatting to a cell range in a Google Sheet.\n\nIMPORTANT: Specify the cell range in ONE of two ways:\n1. Use \'range\' field with A1 notation (RECOMMENDED): "F9", "A1:B5"\n2. Use all four index fields manually: start_row_index, start_column_index, end_row_index, end_column_index\n\nDo NOT provide both - the validator will reject mixed input.'}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_GET_BATCH_VALUES', 'description': 'Tool to return one or more ranges of values from a spreadsheet. Use when you need to retrieve data from multiple ranges in a single request.', 'parameters': {'type': 'object', 'title': 'BatchGetValuesRequest', 'required': ['spreadsheet_id', 'ranges'], 'properties': {'ranges': {'type': 'array', 'items': {'type': 'string', 'properties': {}}, 'title': 'Ranges', 'examples': [['Sheet1!A1:B10'], ['Sheet1!A1:B10', 'Sheet2!C1:D5']], 'minItems': 1, 'description': 'The A1 notation or R1C1 notation of the ranges to retrieve values from. Specify one or more ranges (e.g., [\'Sheet1!A1:B10\', \'Sheet2!C1:D5\']). For sheet names with spaces or special characters, wrap in single quotes (e.g., "\'My Sheet\'!A1:B10"). This parameter is required.'}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'], 'description': "The ID of the spreadsheet to retrieve data from. This is the unique identifier found in the spreadsheet URL between '/d/' and '/edit' (e.g., '1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms'). Please provide a value of type string. This parameter is required."}, 'major_dimension': {'enum': ['DIMENSION_UNSPECIFIED', 'ROWS', 'COLUMNS'], 'type': 'string', 'title': 'MajorDimension', 'description': 'The major dimension for results. Please provide a value of type string.'}, 'value_render_option': {'enum': ['FORMATTED_VALUE', 'UNFORMATTED_VALUE', 'FORMULA'], 'type': 'string', 'title': 'ValueRenderOption', 'description': 'How values should be rendered in the output. Please provide a value of type string.'}, 'date_time_render_option': {'enum': ['SERIAL_NUMBER', 'FORMATTED_STRING'], 'type': 'string', 'title': 'DateTimeRenderOption', 'description': 'How dates, times, and durations should be represented in the output. Please provide a value of type string.'}}}, 'strict': None}, 'type': 'function'}
{'function': {'name': 'GOOGLESHEETS_GET_CONDITIONAL_FORMAT_RULES', 'description': 'List conditional formatting rules for each sheet (or a selected sheet) in a normalized, easy-to-edit form. Use when you need to view, audit, or prepare to modify conditional format rules.', 'parameters': {'type': 'object', 'title': 'GetConditionalFormatRulesRequest', 'required': ['spreadsheet_id'], 'properties': {'sheet_id': {'type': 'integer', 'title': 'Sheet Id', 'examples': [0, 1534097477], 'description': 'Optional filter: return rules only for the sheet with this exact numeric sheetId. If not provided, returns rules for all sheets. If both sheet_title and sheet_id are provided, sheet_id takes precedence. Please provide a value of type integer.'}, 'sheet_title': {'type': 'string', 'title': 'Sheet Title', 'examples': ['Sheet1', 'Sales Data'], 'description': 'Optional filter: return rules only for the sheet with this exact title. If not provided, returns rules for all sheets. Please provide a value of type string.'}, 'spreadsheet_id': {'type': 'string', 'title': 'Spreadsheet Id', 'examples': ['12345abcdefGHIJKLMNOPqrstuvwxyz67890UVWXYZ'], 'description': 'Unique identifier of the Google Spreadsheet, typically found in its URL. Please provide a value of type string. This parameter is required.'}, 'exclude_tables_in_banded_ranges': {'type': 'boolean', 'title': 'Exclude Tables In Banded Ranges', 'description': 'True if tables should be excluded in the banded ranges. False if not set. Please provide a value of type boolean.'}}}, 'strict': None}, 'type': 'function'}

